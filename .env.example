# ===========================================
# BillEasy AI Service - Environment Variables
# ===========================================

# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL - Neon) - SOMENTE LEITURA
# Use a mesma connection string do backend Java
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/billeasy?sslmode=require&pgbouncer=true&connection_limit=5"

# Redis (Cache e Rate Limiting)
REDIS_URL="redis://localhost:6379"

# BillEasy Backend API (Java)
BILLEASY_API_URL="http://localhost:8080"
BILLEASY_SERVICE_TOKEN="seu-token-de-servico-seguro"

# OpenAI (Whisper para transcrição)
OPENAI_API_KEY="sk-..."

# Anthropic (Claude para NLP)
ANTHROPIC_API_KEY="sk-ant-..."

# Configurações de Processamento
MAX_AUDIO_DURATION_SECONDS=30
MAX_FILE_SIZE_MB=10

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20

# Logs
LOG_LEVEL=debug
